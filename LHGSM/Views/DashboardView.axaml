<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LHGSM.Views.DashboardView">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="20">

        <!-- SERVER STATUS -->
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Ellipse Width="16" Height="16" Fill="Red" x:Name="StatusIndicator"/>
            <TextBlock Text="Server Status: Stopped" FontSize="18" />
        </StackPanel>

        <!-- CONTROL BUTTONS -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0 20 0 20">
            <Button Content="Start" Width="120" />
            <Button Content="Stop" Width="120" />
            <Button Content="Restart" Width="120" />
        </StackPanel>

        <!-- SERVER RESOURCE USAGE -->
        <Border Grid.Row="2" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0 0 0 20">
            <StackPanel Spacing="6">

                <TextBlock Text="Server Resource Usage" FontSize="16" FontWeight="Bold" />

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="CPU:" Width="120"/>
                    <TextBlock Text="0%" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="RAM:" Width="120"/>
                    <TextBlock Text="0 MB" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Threads:" Width="120"/>
                    <TextBlock Text="0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Handles:" Width="120"/>
                    <TextBlock Text="0" />
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- LOG OUTPUT -->
        <Border Grid.Row="3" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
            <ScrollViewer>
                <TextBlock Text="Log output will appear here..." Margin="10" />
            </ScrollViewer>
        </Border>

        <!-- QUICK ACTIONS -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="10" Margin="0 20 0 0">
            <Button Content="Open Console" Width="150" />
            <Button Content="Open Server Folder" Width="180" />
            <Button Content="Open Config" Width="150" />
        </StackPanel>

    </Grid>

</UserControl>

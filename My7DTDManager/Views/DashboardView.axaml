<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Server Dashboard" FontSize="24"/>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Start Server" Width="150" Command="{Binding StartServerCommand}"/>
            <Button Content="Stop Server" Width="150" Command="{Binding StopServerCommand}"/>
            <Button Content="Restart Server" Width="150" Command="{Binding RestartServerCommand}"/>
        </StackPanel>

        <TextBlock Text="Status:" FontWeight="Bold" Margin="0,10,0,0"/>
        <TextBlock Text="{Binding ServerStatus}" FontSize="16"/>

        <TextBlock Text="Last output:" FontWeight="Bold" Margin="0,10,0,0"/>
        <Border BorderBrush="Gray" BorderThickness="1" Padding="5" Height="120">
            <ScrollViewer>
                <TextBlock Text="{Binding LastOutput}" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </StackPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="20" Spacing="10">

        <TextBlock Text="Settings" FontSize="24"/>

        <TextBlock Text="Path to 7DaysToDieServer.exe"/>
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBox Text="{Binding ServerExePath}" Width="400"/>
            <Button Content="Browse" Command="{Binding BrowseCommand}"/>
        </StackPanel>

        <Button Content="Save" Width="150" Command="{Binding SaveCommand}" Margin="0,10,0,0"/>

    </StackPanel>

</UserControl>

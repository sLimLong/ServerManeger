<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LHGServerManager.Views"
        x:Class="LHGServerManager.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel">
        Width="1400" Height="900"
        Title="LHG Server Manager">

    <TabControl>
        <TabItem Header="Dashboard">
            <views:DashboardView />
        </TabItem>

        <TabItem Header="Console">
            <views:ConsoleView />
        </TabItem>

        <TabItem Header="Players">
            <views:PlayersView />
        </TabItem>

        <TabItem Header="Config">
            <views:ConfigView />
        </TabItem>

        <TabItem Header="Mods">
            <views:ModsView />
        </TabItem>

        <TabItem Header="Backups">
            <views:BackupsView />
        </TabItem>

        <TabItem Header="Logs">
            <views:LogsView />
        </TabItem>

        <TabItem Header="Settings">
            <views:SettingsView DataContext="{Binding SettingsVM}" />
        </TabItem>

    </TabControl>

</Window>
